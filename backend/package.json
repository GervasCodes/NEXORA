{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "npm --prefix ../database run migrate",
    "db:migrate:status": "npm --prefix ../database run migrate:status",
    "db:seed": "npm --prefix ../database run seed",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "test:watch": "cross-env NODE_ENV=test jest --runInBand --watch",
    "test:coverage": "cross-env NODE_ENV=test jest --runInBand --coverage",
    "test:unit": "cross-env NODE_ENV=test jest --runInBand tests/unit",
    "test:integration": "cross-env NODE_ENV=test jest --runInBand tests/integration",
    "test:db": "cross-env NODE_ENV=test jest --config jest.db.config.js",
    "lint": "eslint ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "mysql2": "^3.22.5",
    "node-cron": "^4.6.0",
    "socket.io": "^4.8.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.0"
  }
}
